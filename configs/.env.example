# ============================================================
# Zimbabwe Property Platform — Environment Configuration
# Copy this file to configs/.env and fill in your values.
# NEVER commit configs/.env to version control.
# ============================================================

# ── Snowflake ──────────────────────────────────────────────
# Your Snowflake account identifier (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=your_account_id

SNOWFLAKE_USER=scraper_svc
SNOWFLAKE_PASSWORD=your_strong_password_here

SNOWFLAKE_DATABASE=ZIM_PROPERTY_DB
SNOWFLAKE_WAREHOUSE=ZIM_PROPERTY_WH
SNOWFLAKE_ROLE=ZIM_DBT_ROLE
SNOWFLAKE_RAW_SCHEMA=RAW
SNOWFLAKE_RAW_TABLE=ZW_PROPERTY_LISTINGS
SNOWFLAKE_BATCH_SIZE=500

# ── dbt ───────────────────────────────────────────────────
# Target environment: dev or prod
DBT_TARGET=dev

# ── Prefect ───────────────────────────────────────────────
# Leave blank to use local Prefect server
PREFECT_API_URL=
PREFECT_API_KEY=

# ── Notifications ─────────────────────────────────────────
# Optional Slack webhook for pipeline alerts
SLACK_WEBHOOK_URL=

# ── Scraper settings ──────────────────────────────────────
# Set to true to use HTTP cache during development
SCRAPY_HTTPCACHE=false

# Comma-separated list of proxy URLs (optional)
# Format: http://user:pass@host:port,http://user:pass@host2:port
PROXY_LIST=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Reports / Checkout ────────────────────────────────────
REPORT_APP_BASE_URL=http://localhost:5055
REPORT_APP_PORT=5055

# Stripe checkout (use sk_test_... keys for testing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin panel password (accessed via /admin/orders?password=xxx)
ADMIN_PASSWORD=

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=hello@vambadata.com

# ── AWS (for cloud deployment, optional) ──────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW=zim-property-raw-data
